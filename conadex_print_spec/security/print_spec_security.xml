<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_print" model="ir.module.category">
        <field name="name">Imprenta Conadex</field>
        <field name="description">Módulos de producción para imprenta Conadex.</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_print_user" model="res.groups">
        <field name="name">Usuario imprenta</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_print_manager" model="res.groups">
        <field name="name">Gestor imprenta</field>
        <field name="implied_ids" eval="[(4, ref('group_print_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
