<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_workcenter_print_spec_form" model="ir.ui.view">
        <field name="name">mrp.workcenter.print.spec.form</field>
        <field name="model">mrp.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Capacidad imprenta" name="print_capacity">
                    <group>
                        <group string="Tipo de máquina">
                            <field name="is_press"/>
                            <field name="press_type" invisible="not is_press"/>
                        </group>
                        <group string="Capacidad de pliego">
                            <field name="max_sheet_w_in" invisible="not is_press"/>
                            <field name="max_sheet_h_in" invisible="not is_press"/>
                            <field name="max_colors_per_pass" invisible="not is_press"/>
                        </group>
                    </group>
                    <group invisible="not is_press">
                        <group string="Rendimiento offset" invisible="press_type != 'offset'">
                            <field name="run_speed_sph"/>
                            <field name="makeready_sheets"/>
                        </group>
                        <group string="Costo digital" invisible="press_type != 'digital'">
                            <field name="cost_per_click"/>
                            <field name="makeready_sheets"/>
                        </group>
                        <group string="Rendimiento gran formato" invisible="press_type != 'gran_formato'">
                            <field name="run_speed_sph"/>
                        </group>
                    </group>
                    <group string="Velocidades por tamaño de pliego"
                           invisible="not is_press or press_type == 'offset'">
                        <field name="speed_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sheet_size_id"/>
                                <field name="speed_value"/>
                                <field name="speed_unit"/>
                                <field name="speed_sph" readonly="1"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
